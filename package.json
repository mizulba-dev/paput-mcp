{
  "name": "paput-mcp",
  "version": "4.2.41",
  "description": "PaPut MCP Server",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "paput-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-cli-assets.mjs",
    "test": "vitest run",
    "test:changed": "vitest run --changed --passWithNoTests",
    "start": "node dist/http.js",
    "start:http": "node dist/http.js",
    "dev": "HOST=127.0.0.1 ts-node --esm src/http.ts",
    "dev:http": "HOST=127.0.0.1 ts-node --esm src/http.ts",
    "check:http": "ts-node --esm src/check-http.ts",
    "test:mcp:transports": "vitest run src/transport.test.ts",
    "prepare": "npm run build",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "version": "node scripts/sync-plugin-version.mjs && git add src/plugin/.claude-plugin/plugin.json src/plugin/.codex-plugin/plugin.json"
  },
  "keywords": [
    "mcp",
    "paput",
    "ai",
    "assistant",
    "memo",
    "output"
  ],
  "author": "mizuko",
  "homepage": "https://paput.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizulba-dev/paput-mcp.git"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE.txt"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "^16.3.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "4.1.7"
  }
}
